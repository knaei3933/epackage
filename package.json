  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true npm run build",
    "build:production": "NODE_ENV=production next build",
    "lighthouse": "node scripts/performance-audit.js",
    "test:performance": "npm run build && npm run lighthouse",
    "test:lighthouse": "npm run build && start-server-and-test start http://localhost:3000 lighthouse",
    "cache:clear": "node scripts/clear-cache.js",
    "cache:verify": "node scripts/verify-cache-clear.js",
    "dev:fresh": "npm run cache:clear && npm run dev",
    "generate:blurhashes": "ts-node scripts/generate-blurhashes.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='src.*\\.(test|spec)\\.[jt]s(x?)$'",
    "test:integration": "jest --testPathPattern='tests.*\\.(test|spec)\\.[jt]s(x?)$'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:logged": "playwright test && node scripts/copy-e2e-logs.js",
    "test:multi-quantity": "jest --testPathPattern='multi-quantity'",
    "test:accessibility": "jest --testPathPattern='accessibility'",
    "test:api": "jest --testPathPattern='api'",
    "test:all": "npm run lint && npm run test:unit && npm run test:e2e && npm run test:performance",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "sync:blog": "ts-node scripts/sync-blog.ts",
    "sync:blog:verbose": "ts-node scripts/sync-blog.ts --verbose"
  },
